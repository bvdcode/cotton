<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cotton.Sync.Desktop.MainWindow"
        Title="Cotton Sync"
        Width="400"
        Height="420"
        MinWidth="380"
        MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CottonAppBackgroundBrush}">
  <Grid RowDefinitions="Auto,*"
        Background="{DynamicResource CottonAppBackgroundBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource CottonSurfaceBrush}"
            BorderBrush="{DynamicResource CottonBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="14,10">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="10">
        <Border Width="34"
                Height="34"
                CornerRadius="8"
                Background="{DynamicResource CottonSurfaceMutedBrush}"
                VerticalAlignment="Center">
          <Image Source="avares://Cotton.Sync.Desktop/Assets/icon-192.png"
                 Width="24"
                 Height="24"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="1"
                    VerticalAlignment="Center">
          <TextBlock Text="Cotton Sync"
                     Foreground="{DynamicResource CottonTextPrimaryBrush}"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding GlobalStatus}"
                     Classes="secondary"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="6"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsDashboardVisible}">
          <Button Content="+"
                  Classes="icon primary"
                  ToolTip.Tip="Add sync folder"
                  Command="{Binding ShowAddSyncPairCommand}" />
          <Button Content="Sync"
                  Classes="compact"
                  Command="{Binding SyncNowCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Background="{DynamicResource CottonSurfaceBrush}"
          IsVisible="{Binding IsSetupVisible}">
      <StackPanel Width="322"
                  Spacing="9"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <StackPanel Spacing="2">
          <TextBlock Text="Set up Cotton Sync"
                     FontSize="20"
                     FontWeight="SemiBold" />
          <TextBlock Text="Connect this computer to Cotton Cloud."
                     Classes="secondary"
                     FontSize="12" />
        </StackPanel>

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
          <TextBox Watermark="Server URL"
                   Text="{Binding ServerUrl}" />
          <Grid Grid.Column="1"
                Width="22"
                Height="22"
                VerticalAlignment="Center">
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonSurfaceMutedBrush}"
                    IsVisible="{Binding IsServerProbeChecking}">
              <TextBlock Text="..."
                         FontSize="10"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonSuccessBrush}"
                    IsVisible="{Binding IsServerVerified}">
              <TextBlock Text="✓"
                         FontSize="12"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonErrorBrush}"
                    IsVisible="{Binding IsServerProbeFailed}">
              <TextBlock Text="!"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </Grid>
        </Grid>
        <TextBlock Text="{Binding ServerProbeStatus}"
                   Classes="secondary"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis"
                   IsVisible="{Binding HasServerProbeStatus}" />
        <TextBox Watermark="Username"
                 Text="{Binding Username}" />
        <TextBox Watermark="Password"
                 PasswordChar="*"
                 Text="{Binding Password}" />
        <TextBox Watermark="TOTP code"
                 Text="{Binding TotpCode}" />
        <Button Content="Sign in"
                Classes="primary"
                HorizontalAlignment="Stretch"
                Command="{Binding SignInCommand}" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          IsVisible="{Binding IsDashboardVisible}">
      <Grid RowDefinitions="Auto,*,Auto"
            Margin="14"
            RowSpacing="12">
        <Border Padding="14"
                CornerRadius="6"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1">
          <Grid ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="10">
            <Border Width="12"
                    Height="12"
                    CornerRadius="6"
                    Background="{DynamicResource CottonSuccessBrush}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1"
                        Spacing="1">
              <TextBlock Text="{Binding GlobalStatus}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding AccountName}"
                         Classes="secondary"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button Grid.Column="2"
                    Content="..."
                    Classes="icon"
                    ToolTip.Tip="Pause"
                    Command="{Binding PauseCommand}" />
          </Grid>
        </Border>

        <Grid Grid.Row="1"
              RowDefinitions="*,150"
              RowSpacing="12">
          <Border Padding="14"
                  CornerRadius="6"
                  Background="{DynamicResource CottonSurfaceBrush}"
                  BorderBrush="{DynamicResource CottonBorderBrush}"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="10">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="6">
                <StackPanel Spacing="1">
                  <TextBlock Text="Folders"
                             FontSize="17"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Local sync roots"
                             Classes="secondary"
                             FontSize="12" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="+"
                        Classes="icon primary"
                        ToolTip.Tip="Add sync folder"
                        Command="{Binding ShowAddSyncPairCommand}" />
                <Button Grid.Column="2"
                        Content="Open"
                        Classes="compact"
                        Command="{Binding OpenFolderCommand}" />
              </Grid>

              <Grid Grid.Row="1">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Width="260"
                            IsVisible="{Binding HasNoSyncPairs}">
                  <Button Content="+"
                          Classes="emptyIcon primary"
                          HorizontalAlignment="Center"
                          ToolTip.Tip="Add sync folder"
                          Command="{Binding ShowAddSyncPairCommand}" />
                  <TextBlock Text="Add a folder"
                             FontSize="18"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="Choose a local folder and a Cotton Cloud folder."
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             Classes="secondary"
                             FontSize="12" />
                </StackPanel>

                <ListBox ItemsSource="{Binding SyncPairs}"
                         SelectedItem="{Binding SelectedSyncPair}"
                         BorderThickness="0"
                         Background="Transparent"
                         IsVisible="{Binding HasSyncPairs}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8"
                              Margin="0,4"
                              CornerRadius="6"
                              Background="{DynamicResource CottonSurfaceMutedBrush}">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="10">
                          <TextBlock Text="{Binding DisplayName}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Status}"
                                     FontSize="12"
                                     Opacity="0.74" />
                          <TextBlock Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     Text="{Binding LocalPath}"
                                     FontSize="12"
                                     TextTrimming="CharacterEllipsis"
                                     Opacity="0.74" />
                          <TextBlock Grid.Row="2"
                                     Grid.ColumnSpan="2"
                                     Text="{Binding RemotePath}"
                                     FontSize="12"
                                     TextTrimming="CharacterEllipsis"
                                     Opacity="0.74" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Padding="14"
                  CornerRadius="6"
                  Background="{DynamicResource CottonSurfaceBrush}"
                  BorderBrush="{DynamicResource CottonBorderBrush}"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="8">
              <TextBlock Text="Activity"
                         FontSize="16"
                         FontWeight="SemiBold" />
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding Activities}"
                       BorderThickness="0"
                       Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="42,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8"
                          Margin="0,4">
                      <TextBlock Text="{Binding Time}"
                                 FontSize="12"
                                 Opacity="0.68" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Details}"
                                 FontSize="12"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding Path}"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis"
                                 Opacity="0.68" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Border>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="6">
          <Button Grid.Column="1"
                  Content="Resume"
                  Classes="compact"
                  Command="{Binding ResumeCommand}" />
          <Button Grid.Column="2"
                  Content="Sign out"
                  Classes="compact"
                  Command="{Binding SignOutCommand}" />
        </Grid>
      </Grid>

      <Border Background="{DynamicResource CottonOverlayBrush}"
              IsVisible="{Binding IsAddSyncPairWizardVisible}">
        <Border Width="420"
                Padding="16"
                CornerRadius="7"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding AddSyncPairWizardTitle}"
                           FontSize="19"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding AddSyncPairWizardSubtitle}"
                           Classes="secondary"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="x"
                      Classes="icon"
                      ToolTip.Tip="Cancel"
                      Command="{Binding CancelAddSyncPairCommand}" />
            </Grid>

            <Grid Grid.Row="1">
              <StackPanel Spacing="12"
                          IsVisible="{Binding IsAddSyncPairLocalStepVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                  <Border Width="24"
                          Height="24"
                          CornerRadius="12"
                          Background="{DynamicResource CottonPrimaryBrush}">
                    <TextBlock Text="1"
                               Foreground="{DynamicResource CottonPrimaryTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="Local folder"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="Cloud"
                             Classes="secondary"
                             FontSize="12"
                             VerticalAlignment="Center" />
                </Grid>

                <Button HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="14"
                        Command="{Binding BrowseLocalFolderCommand}">
                  <Grid RowDefinitions="Auto,Auto"
                        RowSpacing="4">
                    <TextBlock Text="+"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Text="Choose folder"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </Grid>
                </Button>
              </StackPanel>

              <StackPanel Spacing="12"
                          IsVisible="{Binding IsAddSyncPairCloudStepVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                  <Border Width="24"
                          Height="24"
                          CornerRadius="12"
                          Background="{DynamicResource CottonSuccessBrush}">
                    <TextBlock Text="1"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="{Binding LocalFolderPath}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Content="Change"
                          Classes="compact"
                          Command="{Binding BrowseLocalFolderCommand}" />
                </Grid>

                <Border Padding="10"
                        CornerRadius="6"
                        Background="{DynamicResource CottonSurfaceMutedBrush}">
                  <Grid RowDefinitions="Auto,210,Auto"
                        RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                      <Button Content="Up"
                              Classes="compact"
                              Command="{Binding RemoteFolderUpCommand}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding RemoteBrowserPath}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <Button Grid.Column="2"
                              Content="Open"
                              Classes="compact"
                              Command="{Binding OpenRemoteFolderCommand}" />
                    </Grid>

                    <Grid Grid.Row="1">
                      <TextBlock Text="No folders here"
                                 Classes="secondary"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding HasNoRemoteFolders}" />
                      <ListBox ItemsSource="{Binding RemoteFolders}"
                               SelectedItem="{Binding SelectedRemoteFolder}"
                               BorderThickness="0"
                               Background="Transparent"
                               IsVisible="{Binding HasRemoteFolders}">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  Margin="0,5">
                              <TextBlock Text=">"
                                         Classes="secondary"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding RemoteFolderSelectionLabel}"
                               Classes="secondary"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                </Border>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <Button Grid.Column="1"
                          Content="Sync this folder"
                          Classes="primary"
                          Command="{Binding AddSyncPairCommand}" />
                </Grid>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Border>
    </Grid>
  </Grid>
</Window>
