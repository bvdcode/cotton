<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cotton.Sync.Desktop.MainWindow"
        Title="Cotton Sync"
        Width="980"
        Height="680"
        MinWidth="820"
        MinHeight="560"
        Icon="avares://Cotton.Sync.Desktop/Assets/cotton-mark.png">
  <Grid RowDefinitions="Auto,*" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
    <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="20,16">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
        <Image Width="42" Height="42" Source="avares://Cotton.Sync.Desktop/Assets/cotton-mark.png" />
        <StackPanel Grid.Column="1" Spacing="2">
          <TextBlock Text="Cotton Sync" FontSize="22" FontWeight="SemiBold" />
          <TextBlock x:Name="StatusText" Text="Ready" Opacity="0.74" />
          <ProgressBar x:Name="BusyProgress" Height="4" Minimum="0" Maximum="1" Value="0" IsIndeterminate="True" IsVisible="False" />
        </StackPanel>
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button x:Name="SyncOnceButton" Content="Sync Once" Click="SyncOnceButton_Click" />
          <Button x:Name="StartLoopButton" Content="Start" Click="StartLoopButton_Click" />
          <Button x:Name="StopLoopButton" Content="Stop" Click="StopLoopButton_Click" IsEnabled="False" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="18" Margin="20">
      <ScrollViewer Grid.Column="0">
        <StackPanel Spacing="16">
          <Border Padding="16" CornerRadius="6" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <StackPanel Spacing="10">
              <TextBlock Text="Account" FontSize="17" FontWeight="SemiBold" />
              <TextBox x:Name="ServerBox" Watermark="Server URL" />
              <TextBox x:Name="UsernameBox" Watermark="Username" />
              <TextBox x:Name="PasswordInput" Watermark="Password" PasswordChar="*" />
              <TextBox x:Name="TwoFactorBox" Watermark="Two-factor code" />
              <CheckBox x:Name="TrustDeviceBox" Content="Trust this device" />
              <Button x:Name="LoginButton" Content="Login" HorizontalAlignment="Stretch" Click="LoginButton_Click" />
            </StackPanel>
          </Border>

          <Border Padding="16" CornerRadius="6" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <StackPanel Spacing="10">
              <TextBlock Text="Sync Pair" FontSize="17" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="LocalPathBox" Watermark="Local folder" />
                <Button Grid.Column="1" x:Name="BrowseButton" Content="Browse" Click="BrowseButton_Click" />
              </Grid>
              <TextBox x:Name="RemotePathBox" Watermark="Remote folder" />
              <TextBox x:Name="IntervalBox" Watermark="Loop interval seconds" Text="30" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Column="1" Padding="16" CornerRadius="6" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Activity" FontSize="17" FontWeight="SemiBold" />
            <Button Grid.Column="1" x:Name="ClearButton" Content="Clear" Click="ClearButton_Click" />
          </Grid>
          <ListBox Grid.Row="1" x:Name="ActivityList" ItemsSource="{Binding Activities}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="82,120,*" ColumnSpacing="10" Margin="0,4">
                  <TextBlock Text="{Binding Time}" Opacity="0.72" />
                  <TextBlock Grid.Column="1" Text="{Binding Kind}" FontWeight="SemiBold" />
                  <TextBlock Grid.Column="2" Text="{Binding Path}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Path}" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding Details}" Opacity="0.72" TextWrapping="Wrap" ToolTip.Tip="{Binding Details}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
