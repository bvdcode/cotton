<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cotton.Sync.Desktop.MainWindow"
        Title="Cotton Sync"
        Icon="/Assets/icon-192.png"
        Width="344"
        Height="382"
        MinWidth="324"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CottonAppBackgroundBrush}">
  <Grid RowDefinitions="3,Auto,*"
        Background="{DynamicResource CottonAppBackgroundBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource CottonPrimaryBrush}" />

    <Border Grid.Row="1"
            Background="{DynamicResource CottonSurfaceBrush}"
            BorderBrush="{DynamicResource CottonBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,9"
            IsVisible="{Binding IsDashboardVisible}">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="10">
        <Border Width="34"
                Height="34"
                CornerRadius="8"
                Background="{DynamicResource CottonPrimarySoftBrush}"
                VerticalAlignment="Center">
          <Image Source="avares://Cotton.Sync.Desktop/Assets/icon-192.png"
                 Width="24"
                 Height="24"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="1"
                    VerticalAlignment="Center">
          <TextBlock Text="Cotton Sync"
                     Foreground="{DynamicResource CottonTextPrimaryBrush}"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding GlobalStatus}"
                     Classes="secondary"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="5"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsDashboardVisible}">
          <Button Content="+"
                  Classes="icon primary"
                  ToolTip.Tip="Add sync folder"
                  Command="{Binding ShowAddSyncPairCommand}" />
          <Button Content="Sync"
                  Classes="compact"
                  Command="{Binding SyncNowCommand}" />
          <Button Content="..."
                  Classes="icon"
                  ToolTip.Tip="More actions">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Open Cotton Cloud"
                          Command="{Binding OpenWebCommand}" />
                <MenuItem Header="Open local folder"
                          Command="{Binding OpenFolderCommand}" />
                <MenuItem Header="Pause sync"
                          Command="{Binding PauseCommand}" />
                <MenuItem Header="Resume sync"
                          Command="{Binding ResumeCommand}" />
                <MenuItem Header="Settings"
                          Command="{Binding ShowSettingsCommand}" />
                <MenuItem Header="Sign out"
                          Command="{Binding SignOutCommand}" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2"
          Background="{DynamicResource CottonSurfaceBrush}"
          IsVisible="{Binding IsSetupVisible}">
      <StackPanel Width="306"
                  Spacing="7"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <StackPanel Spacing="5"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,6">
          <Border Width="52"
                  Height="52"
                  CornerRadius="12"
                  Background="{DynamicResource CottonPrimarySoftBrush}"
                  HorizontalAlignment="Center">
            <Image Source="avares://Cotton.Sync.Desktop/Assets/icon-192.png"
                   Width="38"
                   Height="38"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="Cotton Sync"
                     FontSize="21"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="Sign in to sync this computer."
                     Classes="secondary"
                     FontSize="12"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <Grid>
          <TextBox Watermark="Server"
                   Padding="8,0,32,0"
                   Text="{Binding ServerUrl}" />
          <Grid Width="22"
                Height="22"
                Margin="0,0,6,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonSurfaceMutedBrush}"
                    IsVisible="{Binding IsServerProbeChecking}">
              <TextBlock Text="..."
                         FontSize="10"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonSuccessBrush}"
                    IsVisible="{Binding IsServerVerified}">
              <TextBlock Text="✓"
                         FontSize="12"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonErrorBrush}"
                    IsVisible="{Binding IsServerProbeFailed}">
              <TextBlock Text="!"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </Grid>
        </Grid>
        <TextBlock Text="{Binding ServerProbeStatus}"
                   Classes="secondary"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis"
                   IsVisible="{Binding HasServerProbeStatus}" />
        <TextBox Watermark="Username"
                 Text="{Binding Username}" />
        <TextBox Watermark="Password"
                 PasswordChar="*"
                 Text="{Binding Password}" />
        <TextBox Watermark="Code (optional)"
                 Text="{Binding TotpCode}" />
        <Button Content="Sign in"
                Classes="primary"
                HorizontalAlignment="Stretch"
                Command="{Binding SignInCommand}" />
        <CheckBox Content="Start with this computer"
                  IsEnabled="{Binding IsStartWithOperatingSystemSupported}"
                  IsChecked="{Binding StartWithOperatingSystem}" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="2"
          IsVisible="{Binding IsDashboardVisible}">
      <Grid RowDefinitions="Auto,Auto,Auto,*"
            Margin="10"
            RowSpacing="8">
        <Border Padding="10"
                CornerRadius="6"
                Background="{DynamicResource CottonPrimarySoftBrush}">
          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="9">
            <Border Width="12"
                    Height="12"
                    CornerRadius="6"
                    Background="{DynamicResource CottonSuccessBrush}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1"
                        Spacing="1">
              <TextBlock Text="{Binding GlobalStatus}"
                         FontSize="15"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Text="{Binding AccountName}"
                         Classes="secondary"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="10"
                CornerRadius="6"
                Background="{DynamicResource CottonErrorSoftBrush}"
                BorderBrush="{DynamicResource CottonErrorBrush}"
                BorderThickness="1"
                IsVisible="{Binding HasActionRequired}">
          <Grid ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8">
            <Border Width="12"
                    Height="12"
                    CornerRadius="6"
                    Background="{DynamicResource CottonErrorBrush}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1"
                        Spacing="1">
              <TextBlock Text="Action required"
                         FontSize="14"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding ActionRequiredMessage}"
                         Classes="secondary"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <Button Content="Retry"
                      Classes="compact"
                      ToolTip.Tip="Run synchronization again"
                      IsVisible="{Binding CanRetryActionRequired}"
                      Command="{Binding SyncNowCommand}" />
              <Button Content="Check"
                      Classes="compact"
                      ToolTip.Tip="Run desktop self-test"
                      Command="{Binding SelfTestCommand}" />
            </StackPanel>
          </Grid>
        </Border>

        <Border Grid.Row="2"
                MaxHeight="94"
                IsVisible="{Binding HasNotifications}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Notifications}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="9"
                          Margin="0,0,0,6"
                          CornerRadius="6"
                          Background="{DynamicResource CottonSurfaceMutedBrush}"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="1">
                      <TextBlock Text="{Binding Title}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Row="1"
                                 Text="{Binding Message}"
                                 Classes="secondary"
                                 FontSize="12"
                                 TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Grid Grid.Row="3"
              RowDefinitions="*,148"
              RowSpacing="8">
          <Border Padding="10"
                  CornerRadius="6"
                  Background="{DynamicResource CottonSurfaceBrush}"
                  BorderBrush="{DynamicResource CottonBorderBrush}"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="10">
              <Grid ColumnDefinitions="*,Auto,Auto"
                    ColumnSpacing="5">
                <StackPanel Spacing="1">
                  <TextBlock Text="Folders"
                             FontSize="16"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Sync roots"
                             Classes="secondary"
                             FontSize="12" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="+"
                        Classes="icon primary"
                        ToolTip.Tip="Add sync folder"
                        Command="{Binding ShowAddSyncPairCommand}" />
                <Button Grid.Column="2"
                        Content="Open"
                        Classes="compact"
                        Command="{Binding OpenFolderCommand}" />
              </Grid>

              <Grid Grid.Row="1">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Width="260"
                            IsVisible="{Binding HasNoSyncPairs}">
                  <Button Content="+"
                          Classes="emptyIcon primary"
                          HorizontalAlignment="Center"
                          ToolTip.Tip="Add sync folder"
                          Command="{Binding ShowAddSyncPairCommand}" />
                  <TextBlock Text="Add a folder"
                             FontSize="17"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="Choose a local folder and a Cotton Cloud folder."
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             Classes="secondary"
                             FontSize="12" />
                </StackPanel>

                <ListBox ItemsSource="{Binding SyncPairs}"
                         SelectedItem="{Binding SelectedSyncPair}"
                         BorderThickness="0"
                         Background="Transparent"
                         IsVisible="{Binding HasSyncPairs}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Padding="8"
                              Margin="0,4"
                              CornerRadius="6"
                              Background="{DynamicResource CottonSurfaceMutedBrush}">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="10">
                          <TextBlock Text="{Binding DisplayName}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Status}"
                                     FontSize="12"
                                     Opacity="0.74" />
                          <TextBlock Grid.Row="1"
                                     Grid.ColumnSpan="2"
                                     Text="{Binding LocalPath}"
                                     FontSize="12"
                                     TextTrimming="CharacterEllipsis"
                                     Opacity="0.74" />
                          <TextBlock Grid.Row="2"
                                     Grid.ColumnSpan="2"
                                     Text="{Binding RemotePath}"
                                     FontSize="12"
                                     TextTrimming="CharacterEllipsis"
                                     Opacity="0.74" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
          </Border>

          <Border Grid.Row="1"
                  Padding="10"
                  CornerRadius="6"
                  Background="{DynamicResource CottonSurfaceBrush}"
                  BorderBrush="{DynamicResource CottonBorderBrush}"
                  BorderThickness="1">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="8">
              <TextBlock Text="Activity"
                         FontSize="16"
                         FontWeight="SemiBold" />
              <Grid Grid.Row="1">
                <StackPanel Spacing="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HasNoActivities}">
                  <TextBlock Text="No activity yet"
                             FontSize="13"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="Sync events will appear here."
                             Classes="secondary"
                             FontSize="12"
                             HorizontalAlignment="Center" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Activities}"
                         BorderThickness="0"
                         Background="Transparent"
                         IsVisible="{Binding HasActivities}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="42,*"
                            RowDefinitions="Auto,Auto"
                            ColumnSpacing="8"
                            Margin="0,4">
                        <TextBlock Text="{Binding Time}"
                                   FontSize="12"
                                   Opacity="0.68" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Details}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Path}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Opacity="0.68" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
          </Border>
        </Grid>

      </Grid>

      <Border Background="{DynamicResource CottonOverlayBrush}"
              IsVisible="{Binding IsAddSyncPairWizardVisible}">
        <Border Width="372"
                Padding="12"
                CornerRadius="7"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding AddSyncPairWizardTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding AddSyncPairWizardSubtitle}"
                           Classes="secondary"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="x"
                      Classes="icon"
                      ToolTip.Tip="Cancel"
                      Command="{Binding CancelAddSyncPairCommand}" />
            </Grid>

            <Grid Grid.Row="1">
              <StackPanel Spacing="12"
                          IsVisible="{Binding IsAddSyncPairLocalStepVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                  <Border Width="24"
                          Height="24"
                          CornerRadius="12"
                          Background="{DynamicResource CottonPrimaryBrush}">
                    <TextBlock Text="1"
                               Foreground="{DynamicResource CottonPrimaryTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="Local folder"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="Cloud folder"
                             Classes="secondary"
                             FontSize="12"
                             VerticalAlignment="Center" />
                </Grid>

                <Button HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="14"
                        Command="{Binding BrowseLocalFolderCommand}">
                  <Grid RowDefinitions="Auto,Auto"
                        RowSpacing="4">
                    <TextBlock Text="+"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Text="Choose folder"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </Grid>
                </Button>
              </StackPanel>

              <StackPanel Spacing="12"
                          IsVisible="{Binding IsAddSyncPairCloudStepVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                  <Border Width="24"
                          Height="24"
                          CornerRadius="12"
                          Background="{DynamicResource CottonSuccessBrush}">
                    <TextBlock Text="1"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="{Binding LocalFolderPath}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Content="Change"
                          Classes="compact"
                          Command="{Binding BrowseLocalFolderCommand}" />
                </Grid>

                <Border Padding="10"
                        CornerRadius="6"
                        Background="{DynamicResource CottonSurfaceMutedBrush}">
                  <Grid RowDefinitions="Auto,196,Auto"
                        RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="6">
                      <Button Content="Up"
                              Classes="icon"
                              ToolTip.Tip="Go up"
                              Command="{Binding RemoteFolderUpCommand}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding RemoteBrowserPath}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <Button Grid.Column="2"
                              Content="Open"
                              Classes="compact"
                              Command="{Binding OpenRemoteFolderCommand}" />
                    </Grid>

                    <Grid Grid.Row="1">
                      <StackPanel Spacing="3"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding HasNoRemoteFolders}">
                        <TextBlock Text="No folders here"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="The current cloud folder can still be selected."
                                   Classes="secondary"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <ListBox ItemsSource="{Binding RemoteFolders}"
                               SelectedItem="{Binding SelectedRemoteFolder}"
                               BorderThickness="0"
                               Background="Transparent"
                               IsVisible="{Binding HasRemoteFolders}">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  Margin="0,5">
                              <TextBlock Text=">"
                                         Classes="secondary"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding RemoteFolderSelectionLabel}"
                               Classes="secondary"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                </Border>

                <StackPanel Spacing="7"
                            IsVisible="{Binding IsFutureSyncModesVisible}">
                  <TextBlock Text="Sync mode"
                             FontSize="12"
                             FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="8">
                    <Border Padding="9"
                            CornerRadius="6"
                            Background="{DynamicResource CottonPrimarySoftBrush}"
                            BorderBrush="{DynamicResource CottonPrimaryBrush}"
                            BorderThickness="1">
                      <Grid RowDefinitions="Auto,Auto"
                            RowSpacing="2">
                        <TextBlock Text="{Binding SelectedSyncModeLabel}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Text="Available"
                                   Classes="secondary"
                                   FontSize="11" />
                      </Grid>
                    </Border>
                    <Border Grid.Column="1"
                            Padding="9"
                            CornerRadius="6"
                            Background="{DynamicResource CottonSurfaceMutedBrush}"
                            BorderBrush="{DynamicResource CottonBorderBrush}"
                            BorderThickness="1"
                            Opacity="0.62">
                      <Grid RowDefinitions="Auto,Auto"
                            RowSpacing="2">
                        <TextBlock Text="Virtual files"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Text="Not implemented"
                                   Classes="secondary"
                                   FontSize="11" />
                      </Grid>
                    </Border>
                  </Grid>
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <Button Grid.Column="1"
                          Content="Sync folder"
                          Classes="primary"
                          Command="{Binding AddSyncPairCommand}" />
                </Grid>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Border>

      <Border Background="{DynamicResource CottonOverlayBrush}"
              IsVisible="{Binding IsSettingsVisible}">
        <Border Width="372"
                Padding="12"
                CornerRadius="7"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="Settings"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="Account, startup, and diagnostics"
                           Classes="secondary"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="x"
                      Classes="icon"
                      ToolTip.Tip="Close"
                      Command="{Binding CloseSettingsCommand}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          MaxHeight="432"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="12">
                <StackPanel Spacing="3">
                  <TextBlock Text="Account"
                             FontWeight="SemiBold" />
                  <TextBlock Text="{Binding AccountName}"
                             FontSize="12"
                             TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding ServerUrl}"
                             Classes="secondary"
                             FontSize="12"
                             TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <Border Height="1"
                        Background="{DynamicResource CottonBorderBrush}" />

                <StackPanel Spacing="6">
                  <TextBlock Text="Startup"
                             FontWeight="SemiBold" />
                  <CheckBox Content="Start with this computer"
                            IsEnabled="{Binding IsStartWithOperatingSystemSupported}"
                            IsChecked="{Binding StartWithOperatingSystem}" />
                  <TextBlock Text="{Binding AutostartStatusText}"
                             Classes="secondary"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding TrayLifecycleStatusText}"
                             Classes="secondary"
                             FontSize="12"
                             TextWrapping="Wrap"
                             IsVisible="{Binding IsTrayLifecycleUnsupported}" />
                </StackPanel>

                <Border Height="1"
                        Background="{DynamicResource CottonBorderBrush}" />

                <StackPanel Spacing="6">
                  <TextBlock Text="Appearance"
                             FontWeight="SemiBold" />
                  <ComboBox SelectedIndex="{Binding ThemeModeIndex}"
                            HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="System" />
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="Dark" />
                  </ComboBox>
                </StackPanel>

                <Border Height="1"
                        Background="{DynamicResource CottonBorderBrush}" />

                <StackPanel Spacing="6">
                  <TextBlock Text="Notifications"
                             FontWeight="SemiBold" />
                  <CheckBox Content="Show desktop notifications"
                            IsChecked="{Binding EnableNotifications}" />
                  <TextBlock Text="Initial sync, conflicts, and action-required errors."
                             Classes="secondary"
                             FontSize="12"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Border Height="1"
                        Background="{DynamicResource CottonBorderBrush}" />

                <StackPanel Spacing="7">
                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="8">
                    <TextBlock Text="Sync folders"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="+"
                            Classes="icon"
                            ToolTip.Tip="Add sync folder"
                            Command="{Binding ShowAddSyncPairCommand}" />
                  </Grid>
                  <Border Padding="9"
                          CornerRadius="6"
                          Background="{DynamicResource CottonSurfaceMutedBrush}"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1"
                          IsVisible="{Binding HasNoSyncPairs}">
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                      <StackPanel Spacing="2">
                        <TextBlock Text="No folders configured"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Add a local folder and match it to Cotton Cloud."
                                   Classes="secondary"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="+"
                              Classes="icon primary"
                              ToolTip.Tip="Add sync folder"
                              Command="{Binding ShowAddSyncPairCommand}" />
                    </Grid>
                  </Border>
                  <Border MaxHeight="128"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          IsVisible="{Binding HasSyncPairs}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                      <ListBox ItemsSource="{Binding SyncPairs}"
                               SelectedItem="{Binding SelectedSyncPair}"
                               BorderThickness="0"
                               Background="Transparent">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8"
                                  Margin="8,6">
                              <TextBlock Text="{Binding DisplayName}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Status}"
                                         Classes="secondary"
                                         FontSize="12" />
                              <TextBlock Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding LocalPath}"
                                         Classes="secondary"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </ScrollViewer>
                  </Border>
                  <StackPanel Orientation="Horizontal"
                              Spacing="6"
                              IsVisible="{Binding HasSyncPairs}">
                    <Button Content="Open"
                            Classes="compact"
                            Command="{Binding OpenFolderCommand}" />
                    <Button Content="{Binding SelectedSyncPair.ToggleEnabledLabel}"
                            Classes="compact"
                            Command="{Binding ToggleSelectedSyncPairEnabledCommand}" />
                    <Button Content="Remove"
                            Classes="compact"
                            Command="{Binding RemoveSelectedSyncPairCommand}" />
                  </StackPanel>
                </StackPanel>

                <Border Height="1"
                        Background="{DynamicResource CottonBorderBrush}" />

                <StackPanel Spacing="7">
                  <TextBlock Text="Diagnostics"
                             FontWeight="SemiBold" />
                  <Border MaxHeight="112"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding DiagnosticsItems}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="108,*"
                                  ColumnSpacing="8"
                                  Margin="8,5">
                              <TextBlock Text="{Binding Label}"
                                         Classes="secondary"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Value}"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                  <StackPanel Orientation="Horizontal"
                              Spacing="6">
                    <Button Content="Run self-test"
                            Classes="compact"
                            Command="{Binding SelfTestCommand}" />
                    <Button Content="Export"
                            Classes="compact"
                            ToolTip.Tip="Export diagnostics bundle"
                            Command="{Binding ExportDiagnosticsCommand}" />
                  </StackPanel>
                  <TextBlock Text="Run self-test to check this computer."
                             Classes="secondary"
                             FontSize="12"
                             TextWrapping="Wrap"
                             IsVisible="{Binding HasNoSelfTestItems}" />
                  <Border MaxHeight="118"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1"
                          CornerRadius="6"
                          IsVisible="{Binding HasSelfTestItems}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                      <ItemsControl ItemsSource="{Binding SelfTestItems}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="8"
                                  Margin="8,6">
                              <TextBlock Text="{Binding Name}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding ResultText}"
                                         Classes="secondary"
                                         FontSize="12" />
                              <TextBlock Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Details}"
                                         Classes="secondary"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Border>
                </StackPanel>

                <Border Height="1"
                        Background="{DynamicResource CottonBorderBrush}" />

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Cotton Sync Desktop"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Full mirror sync client"
                               Classes="secondary"
                               FontSize="12" />
                  </StackPanel>
                  <Button Grid.Column="1"
                          Content="Sign out"
                          Classes="compact"
                          Command="{Binding SignOutCommand}" />
                </Grid>
              </StackPanel>
            </ScrollViewer>
          </Grid>
        </Border>
      </Border>
    </Grid>
  </Grid>
</Window>
