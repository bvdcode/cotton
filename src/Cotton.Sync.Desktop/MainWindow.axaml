<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cotton.Sync.Desktop.MainWindow"
        Title="Cotton Sync"
        Width="980"
        Height="680"
        MinWidth="760"
        MinHeight="560">
  <Grid RowDefinitions="Auto,*"
        Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="22,14">
      <Grid ColumnDefinitions="*,Auto"
            ColumnSpacing="16">
        <StackPanel Spacing="2">
          <TextBlock Text="Cotton Sync"
                     FontSize="21"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding GlobalStatus}"
                     Opacity="0.68" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsDashboardVisible}">
          <Button Content="Open"
                  Command="{Binding OpenFolderCommand}" />
          <Button Content="Sync"
                  Command="{Binding SyncNowCommand}" />
          <Button Content="Pause"
                  Command="{Binding PauseCommand}" />
          <Button Content="Resume"
                  Command="{Binding ResumeCommand}" />
          <Button Content="Sign out"
                  Command="{Binding SignOutCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          IsVisible="{Binding IsSetupVisible}">
      <Border Width="430"
              Padding="24"
              CornerRadius="6"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="14">
          <StackPanel Spacing="3">
            <TextBlock Text="Set up Cotton Sync"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Text="Sign in to connect this computer."
                       Opacity="0.68" />
          </StackPanel>

          <TextBox Watermark="Server URL"
                   Text="{Binding ServerUrl}" />
          <TextBox Watermark="Username"
                   Text="{Binding Username}" />
          <TextBox Watermark="Password"
                   PasswordChar="*"
                   Text="{Binding Password}" />
          <TextBox Watermark="TOTP code"
                   Text="{Binding TotpCode}" />
          <CheckBox Content="Trust this device"
                    IsChecked="{Binding TrustDevice}" />
          <Button Content="Sign in"
                  HorizontalAlignment="Stretch"
                  Command="{Binding SignInCommand}" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.Row="1"
          RowDefinitions="Auto,*"
          Margin="22"
          RowSpacing="18"
          IsVisible="{Binding IsDashboardVisible}">
      <Border Padding="16"
              CornerRadius="6"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="16">
          <StackPanel Spacing="3">
            <TextBlock Text="{Binding AccountName}"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Text="This computer is connected to Cotton Sync."
                       Opacity="0.68" />
          </StackPanel>
          <Button Grid.Column="1"
                  Content="Sign out"
                  VerticalAlignment="Center"
                  Command="{Binding SignOutCommand}" />
        </Grid>
      </Border>

      <Grid Grid.Row="1"
            ColumnDefinitions="*,310"
            ColumnSpacing="18">
        <Border Padding="16"
                CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
          <Grid RowDefinitions="Auto,Auto,*"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
              <TextBlock Text="Sync folders"
                         FontSize="17"
                         FontWeight="SemiBold" />
              <Button Grid.Column="1"
                      Content="Open selected"
                      Command="{Binding OpenFolderCommand}" />
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="8">
              <TextBox Watermark="Local folder"
                       Text="{Binding LocalFolderPath}" />
              <Button Grid.Column="1"
                      Content="Browse"
                      Command="{Binding BrowseLocalFolderCommand}" />
              <TextBox Grid.Column="2"
                       Watermark="Remote folder"
                       Text="{Binding RemoteFolderPath}" />
              <Button Grid.Row="1"
                      Grid.ColumnSpan="3"
                      Content="Add sync folder"
                      HorizontalAlignment="Stretch"
                      Command="{Binding AddSyncPairCommand}" />
            </Grid>

            <Grid Grid.Row="2">
              <TextBlock Text="No folders are syncing yet."
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Opacity="0.62"
                         IsVisible="{Binding HasNoSyncPairs}" />
              <ListBox ItemsSource="{Binding SyncPairs}"
                       SelectedItem="{Binding SelectedSyncPair}"
                       IsVisible="{Binding HasSyncPairs}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto"
                          Margin="0,8"
                          ColumnSpacing="12">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Status}"
                                 Opacity="0.72" />
                      <TextBlock Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding LocalPath}"
                                 TextTrimming="CharacterEllipsis"
                                 Opacity="0.74" />
                      <TextBlock Grid.Row="2"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding RemotePath}"
                                 TextTrimming="CharacterEllipsis"
                                 Opacity="0.74" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Padding="16"
                CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="12">
            <TextBlock Text="Recent activity"
                       FontSize="17"
                       FontWeight="SemiBold" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Activities}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="48,*"
                        RowDefinitions="Auto,Auto,Auto"
                        ColumnSpacing="8"
                        Margin="0,7">
                    <TextBlock Text="{Binding Time}"
                               Opacity="0.68" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Kind}"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Path}"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.8" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding Details}"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.72" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
