<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cotton.Sync.Desktop.MainWindow"
        Title="Cotton Sync"
        Width="420"
        Height="430"
        MinWidth="400"
        MinHeight="410"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CottonAppBackgroundBrush}">
  <Grid RowDefinitions="Auto,*"
        Background="{DynamicResource CottonAppBackgroundBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource CottonSurfaceBrush}"
            BorderBrush="{DynamicResource CottonBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="18,12">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="12">
        <Border Width="34"
                Height="34"
                CornerRadius="8"
                Background="{DynamicResource CottonSurfaceMutedBrush}"
                VerticalAlignment="Center">
          <Image Source="avares://Cotton.Sync.Desktop/Assets/icon-192.png"
                 Width="24"
                 Height="24"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="2"
                    VerticalAlignment="Center">
          <TextBlock Text="Cotton Sync"
                     Foreground="{DynamicResource CottonTextPrimaryBrush}"
                     FontSize="18"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding GlobalStatus}"
                     Classes="secondary"
                     FontSize="12" />
        </StackPanel>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsDashboardVisible}">
          <Button Content="Open"
                  Command="{Binding OpenFolderCommand}" />
          <Button Content="Sync"
                  Command="{Binding SyncNowCommand}" />
          <Button Content="Pause"
                  Command="{Binding PauseCommand}" />
          <Button Content="Resume"
                  Command="{Binding ResumeCommand}" />
          <Button Content="Sign out"
                  Command="{Binding SignOutCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1"
          Background="{DynamicResource CottonSurfaceBrush}"
          IsVisible="{Binding IsSetupVisible}">
      <StackPanel Width="340"
                  Spacing="10"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <StackPanel Spacing="2">
          <TextBlock Text="Set up Cotton Sync"
                     FontSize="21"
                     FontWeight="SemiBold" />
          <TextBlock Text="Sign in to connect this computer."
                     Classes="secondary" />
        </StackPanel>

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="8">
          <TextBox Watermark="Server URL"
                   Text="{Binding ServerUrl}" />
          <Grid Grid.Column="1"
                Width="22"
                Height="22"
                VerticalAlignment="Center">
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonSurfaceMutedBrush}"
                    IsVisible="{Binding IsServerProbeChecking}">
              <TextBlock Text="..."
                         FontSize="10"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonSuccessBrush}"
                    IsVisible="{Binding IsServerVerified}">
              <TextBlock Text="✓"
                         FontSize="12"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
            <Border Width="18"
                    Height="18"
                    CornerRadius="9"
                    Background="{DynamicResource CottonErrorBrush}"
                    IsVisible="{Binding IsServerProbeFailed}">
              <TextBlock Text="!"
                         Foreground="White"
                         FontSize="12"
                         FontWeight="Bold"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>
          </Grid>
        </Grid>
        <TextBlock Text="{Binding ServerProbeStatus}"
                   Classes="secondary"
                   FontSize="12"
                   IsVisible="{Binding HasServerProbeStatus}" />
        <TextBox Watermark="Username"
                 Text="{Binding Username}" />
        <TextBox Watermark="Password"
                 PasswordChar="*"
                 Text="{Binding Password}" />
        <TextBox Watermark="TOTP code"
                 Text="{Binding TotpCode}" />
        <Button Content="Sign in"
                Classes="primary"
                HorizontalAlignment="Stretch"
                Command="{Binding SignInCommand}" />
      </StackPanel>
    </Grid>

    <Grid Grid.Row="1"
          IsVisible="{Binding IsDashboardVisible}">
      <Grid ColumnDefinitions="*,300"
            Margin="22"
            ColumnSpacing="18">
        <Border Padding="16"
              CornerRadius="6"
              Background="{DynamicResource CottonSurfaceBrush}"
              BorderBrush="{DynamicResource CottonBorderBrush}"
              BorderThickness="1">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="Sync folders"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock Text="Folders connected on this computer."
                           Classes="secondary" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="+"
                      Width="34"
                      Height="34"
                      FontSize="18"
                      FontWeight="SemiBold"
                      VerticalAlignment="Center"
                      Command="{Binding ShowAddSyncPairCommand}" />
              <Button Grid.Column="2"
                      Content="Open"
                      VerticalAlignment="Center"
                      Command="{Binding OpenFolderCommand}" />
            </Grid>

            <Grid Grid.Row="1">
              <StackPanel HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Spacing="12"
                          Width="320"
                          IsVisible="{Binding HasNoSyncPairs}">
                <Button Content="+"
                        Width="46"
                        Height="46"
                        FontSize="24"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        Command="{Binding ShowAddSyncPairCommand}" />
                <TextBlock Text="No sync folders"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Add a folder to start syncing this computer with Cotton Cloud."
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Classes="secondary" />
              </StackPanel>

              <ListBox ItemsSource="{Binding SyncPairs}"
                       SelectedItem="{Binding SelectedSyncPair}"
                       IsVisible="{Binding HasSyncPairs}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto"
                          Margin="0,8"
                          ColumnSpacing="12">
                      <TextBlock Text="{Binding DisplayName}"
                                 FontWeight="SemiBold" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Status}"
                                 Opacity="0.72" />
                      <TextBlock Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding LocalPath}"
                                 TextTrimming="CharacterEllipsis"
                                 Opacity="0.74" />
                      <TextBlock Grid.Row="2"
                                 Grid.ColumnSpan="2"
                                 Text="{Binding RemotePath}"
                                 TextTrimming="CharacterEllipsis"
                                 Opacity="0.74" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </Grid>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="Auto,*"
              RowSpacing="14">
          <Border Padding="16"
                CornerRadius="6"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1">
          <StackPanel Spacing="10">
            <StackPanel Spacing="2">
              <TextBlock Text="{Binding AccountName}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Text="Connected account"
                         Classes="secondary" />
            </StackPanel>
            <Button Content="Sign out"
                    HorizontalAlignment="Stretch"
                    Command="{Binding SignOutCommand}" />
          </StackPanel>
          </Border>

          <Border Grid.Row="1"
                Padding="16"
                CornerRadius="6"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="12">
            <TextBlock Text="Recent activity"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Activities}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="48,*"
                        RowDefinitions="Auto,Auto,Auto"
                        ColumnSpacing="8"
                        Margin="0,7">
                    <TextBlock Text="{Binding Time}"
                               Opacity="0.68" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Kind}"
                               FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Path}"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.8" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding Details}"
                               TextTrimming="CharacterEllipsis"
                               Opacity="0.72" />
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
          </Border>
        </Grid>
      </Grid>

      <Border Background="{DynamicResource CottonOverlayBrush}"
              IsVisible="{Binding IsAddSyncPairWizardVisible}">
        <Border Width="480"
                Padding="18"
                CornerRadius="6"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <StackPanel Spacing="12">
            <StackPanel Spacing="2">
              <TextBlock Text="Add sync folder"
                         FontSize="19"
                         FontWeight="SemiBold" />
              <TextBlock Text="Choose a local folder, then choose the Cotton Cloud folder."
                         TextWrapping="Wrap"
                         Classes="secondary" />
            </StackPanel>

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <TextBox Watermark="Local folder"
                       Text="{Binding LocalFolderPath}" />
              <Button Grid.Column="1"
                      Content="Browse"
                      Command="{Binding BrowseLocalFolderCommand}" />
            </Grid>
            <Grid RowDefinitions="Auto,170"
                  RowSpacing="8">
              <Grid ColumnDefinitions="Auto,*,Auto"
                    ColumnSpacing="8">
                <Button Content="Up"
                        Command="{Binding RemoteFolderUpCommand}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding RemoteBrowserPath}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <Button Grid.Column="2"
                        Content="Open"
                        Command="{Binding OpenRemoteFolderCommand}" />
              </Grid>

              <Grid Grid.Row="1">
                <TextBlock Text="No cloud folders in this folder."
                           Classes="secondary"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding HasNoRemoteFolders}" />
                <ListBox ItemsSource="{Binding RemoteFolders}"
                         SelectedItem="{Binding SelectedRemoteFolder}"
                         IsVisible="{Binding HasRemoteFolders}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"
                                 TextTrimming="CharacterEllipsis"
                                 Margin="0,5" />
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
              <Button Grid.Column="1"
                      Content="Cancel"
                      Command="{Binding CancelAddSyncPairCommand}" />
              <Button Grid.Column="2"
                      Content="Add"
                      Classes="primary"
                      Command="{Binding AddSyncPairCommand}" />
            </Grid>
          </StackPanel>
        </Border>
      </Border>
    </Grid>
  </Grid>
</Window>
