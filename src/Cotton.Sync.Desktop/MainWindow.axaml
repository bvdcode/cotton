<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Cotton.Sync.Desktop.MainWindow"
        Title="Cotton Sync"
        Icon="/Assets/app.ico"
        Width="336"
        Height="288"
        MinWidth="316"
        MinHeight="280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CottonAppBackgroundBrush}">
  <Grid RowDefinitions="3,Auto,*"
        Background="{DynamicResource CottonAppBackgroundBrush}">
    <Border Grid.Row="0"
            Background="{DynamicResource CottonPrimaryBrush}" />

    <Border Grid.Row="1"
            Background="{DynamicResource CottonSurfaceBrush}"
            BorderBrush="{DynamicResource CottonBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="12,9"
            IsVisible="{Binding IsDashboardVisible}">
      <Grid ColumnDefinitions="Auto,*,Auto"
            ColumnSpacing="10">
        <Border Width="34"
                Height="34"
                CornerRadius="8"
                Background="{DynamicResource CottonPrimarySoftBrush}"
                VerticalAlignment="Center">
          <Image Source="avares://Cotton.Sync.Desktop/Assets/icon-192.png"
                 Width="24"
                 Height="24"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1"
                    Spacing="1"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding HeaderTitleText}"
                     Foreground="{DynamicResource CottonTextPrimaryBrush}"
                     FontSize="17"
                     FontWeight="SemiBold" />
          <TextBlock Text="{Binding HeaderStatusText}"
                     Classes="secondary"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="5"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsDashboardVisible}">
          <Button Content="↻"
                  Classes="icon"
                  ToolTip.Tip="Sync now"
                  IsVisible="{Binding CanSyncNow}"
                  Command="{Binding SyncNowCommand}" />
          <Button Content="..."
                  Classes="icon"
                  ToolTip.Tip="More actions">
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Open Cotton Cloud"
                          Command="{Binding OpenWebCommand}" />
                <MenuItem Header="{Binding PauseResumeSyncLabel}"
                          IsVisible="{Binding CanTogglePauseResumeSync}"
                          Command="{Binding PauseResumeCommand}" />
                <MenuItem Header="Settings"
                          Command="{Binding ShowSettingsCommand}" />
                <MenuItem Header="Sign out"
                          Command="{Binding SignOutCommand}" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2"
          Background="{DynamicResource CottonSurfaceBrush}"
          IsVisible="{Binding IsSetupVisible}">
      <StackPanel Width="296"
                  Spacing="9"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <StackPanel Spacing="4"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,4">
          <Border Width="50"
                  Height="50"
                  CornerRadius="10"
                  Background="{DynamicResource CottonPrimaryBrush}"
                  HorizontalAlignment="Center"
                  BorderBrush="{DynamicResource CottonSecondaryBrush}"
                  BorderThickness="1">
            <Image Source="avares://Cotton.Sync.Desktop/Assets/icon-192.png"
                   Width="36"
                   Height="36"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="{Binding SetupTitle}"
                     FontSize="20"
                     FontWeight="SemiBold"
                     TextAlignment="Center"
                     HorizontalAlignment="Center"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding SetupSubtitle}"
                     Classes="secondary"
                     FontSize="12"
                     TextAlignment="Center"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <Border Padding="8"
                CornerRadius="6"
                Background="{DynamicResource CottonErrorSoftBrush}"
                BorderBrush="{DynamicResource CottonErrorBrush}"
                BorderThickness="1"
                MinHeight="34"
                MaxHeight="38"
                ToolTip.Tip="{Binding ActionRequiredMessage}"
                Opacity="{Binding ActionRequiredOpacity}"
                IsHitTestVisible="{Binding HasActionRequired}">
          <TextBlock Text="{Binding ActionRequiredMessage}"
                     FontSize="12"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"
                     VerticalAlignment="Center" />
        </Border>

        <StackPanel Spacing="8"
                    IsVisible="{Binding IsServerStepVisible}">
          <Grid>
            <TextBox PlaceholderText="Server address"
                     Padding="8,0,34,0"
                     Text="{Binding ServerUrl}" />
            <Grid Width="24"
                  Height="24"
                  Margin="0,0,5,0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
              <Border Width="18"
                      Height="18"
                      CornerRadius="9"
                      Background="{DynamicResource CottonSurfaceMutedBrush}"
                      IsVisible="{Binding IsServerProbeChecking}">
                <TextBlock Text="..."
                           FontSize="10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <Border Width="18"
                      Height="18"
                      CornerRadius="9"
                      Background="{DynamicResource CottonErrorBrush}"
                      IsVisible="{Binding IsServerProbeFailed}">
                <TextBlock Text="!"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
            </Grid>
          </Grid>
          <TextBlock Text="{Binding ServerProbeStatus}"
                     Classes="secondary"
                     FontSize="12"
                     TextTrimming="CharacterEllipsis"
                     IsVisible="{Binding HasServerProbeStatus}" />
        </StackPanel>

        <StackPanel Spacing="8"
                    IsVisible="{Binding IsSignInStepVisible}">
          <Border Padding="8"
                  CornerRadius="6"
                  Background="{DynamicResource CottonPrimarySoftBrush}">
            <Grid ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="7">
              <Border Width="18"
                      Height="18"
                      CornerRadius="9"
                      Background="{DynamicResource CottonSuccessBrush}"
                      VerticalAlignment="Center">
                <TextBlock Text="✓"
                           FontSize="12"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
              </Border>
              <TextBlock Grid.Column="1"
                         Text="{Binding ServerUrl}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis"
                         VerticalAlignment="Center" />
              <Button Grid.Column="2"
                      Content="Change"
                      Classes="compact"
                      Command="{Binding ChangeServerCommand}" />
            </Grid>
          </Border>

          <TextBox PlaceholderText="Username"
                   Text="{Binding Username}" />
          <TextBox PlaceholderText="Password"
                   PasswordChar="*"
                   Text="{Binding Password}" />
          <TextBox PlaceholderText="2FA code"
                   Text="{Binding TotpCode}" />
          <Button Content="Sign in"
                  Classes="primary"
                  HorizontalAlignment="Stretch"
                  Command="{Binding SignInCommand}" />
        </StackPanel>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="2"
          Margin="10"
          RowDefinitions="Auto,*"
          RowSpacing="8"
          IsVisible="{Binding IsDashboardVisible}">
      <StackPanel Grid.Row="0"
                  Spacing="8"
                  IsVisible="{Binding IsDashboardChromeVisible}">
          <Border Padding="10"
                  CornerRadius="6"
                  Classes="statusCard"
                  Classes.actionRequired="{Binding HasStatusAttention}"
                  IsVisible="{Binding IsStatusCardVisible}">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="9">
              <Border Width="12"
                      Height="12"
                      CornerRadius="6"
                      Classes="statusDot"
                      Classes.actionRequired="{Binding HasStatusAttention}"
                      VerticalAlignment="Center" />
              <StackPanel Grid.Column="1"
                          Spacing="1">
                <TextBlock Text="{Binding StatusCardTitle}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding StatusCardDetailText}"
                           Classes="secondary"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding HasStatusCardDetail}" />
              </StackPanel>
            </Grid>
          </Border>

          <Border Padding="10"
                  CornerRadius="6"
                  Background="{DynamicResource CottonSurfaceBrush}"
                  BorderBrush="{DynamicResource CottonBorderBrush}"
                  BorderThickness="1"
                  IsVisible="{Binding HasCurrentWorkProgress}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="6">
              <TextBlock Text="{Binding CurrentWorkProgressTitle}"
                         FontSize="13"
                         FontWeight="SemiBold"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="1"
                         Text="{Binding CurrentWorkProgressDetails}"
                         Classes="secondary"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis" />
              <TextBlock Grid.Row="2"
                         Text="{Binding CurrentWorkProgressSecondaryDetails}"
                         Classes="secondary"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis"
                         IsVisible="{Binding HasCurrentWorkProgressSecondaryDetails}" />
              <ProgressBar Grid.Row="3"
                           Height="4"
                           Minimum="0"
                           Maximum="100"
                           Value="{Binding CurrentWorkProgressValue}"
                           IsIndeterminate="{Binding IsCurrentWorkProgressIndeterminate}" />
            </Grid>
          </Border>

        <Border Padding="10"
                CornerRadius="6"
                Background="{DynamicResource CottonErrorSoftBrush}"
                BorderBrush="{DynamicResource CottonErrorBrush}"
                BorderThickness="1"
                IsVisible="{Binding HasActionRequired}">
          <Grid ColumnDefinitions="Auto,*,Auto"
                ColumnSpacing="8">
            <Border Width="12"
                    Height="12"
                    CornerRadius="6"
                    Background="{DynamicResource CottonErrorBrush}"
                    VerticalAlignment="Center" />
            <StackPanel Grid.Column="1"
                        Spacing="1">
              <TextBlock Text="Action required"
                         FontSize="14"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding ActionRequiredMessage}"
                         Classes="secondary"
                         FontSize="12"
                         MaxLines="3"
                         TextWrapping="Wrap"
                         ToolTip.Tip="{Binding ActionRequiredMessage}"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="6"
                        VerticalAlignment="Center">
              <Button Content="↻"
                      Classes="icon"
                      ToolTip.Tip="Run synchronization again"
                      IsVisible="{Binding CanRetryActionRequired}"
                      Command="{Binding SyncNowCommand}" />
              <Button Content="✓"
                      Classes="icon"
                      ToolTip.Tip="Run desktop self-test"
                      Command="{Binding SelfTestCommand}" />
            </StackPanel>
          </Grid>
        </Border>

        <Border MaxHeight="94"
                IsVisible="{Binding HasNotifications}">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Notifications}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="9"
                          Margin="0,0,0,6"
                          CornerRadius="6"
                          Background="{DynamicResource CottonSurfaceMutedBrush}"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="1">
                      <TextBlock Text="{Binding Title}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Row="1"
                                 Text="{Binding Message}"
                                 Classes="secondary"
                                 FontSize="12"
                                 TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Border Padding="10"
                MaxHeight="116"
                CornerRadius="6"
                Background="{DynamicResource CottonErrorSoftBrush}"
                BorderBrush="{DynamicResource CottonErrorBrush}"
                BorderThickness="1"
                IsVisible="{Binding HasConflicts}">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="7">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="6">
              <StackPanel Spacing="1">
                <TextBlock Text="Conflicts"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding ConflictCountLabel}"
                           Classes="secondary"
                           FontSize="12" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="↻"
                      Classes="icon"
                      ToolTip.Tip="Run synchronization again"
                      Command="{Binding SyncNowCommand}" />
              <Button Grid.Column="2"
                      Content="↗"
                      Classes="icon"
                      ToolTip.Tip="Open selected conflict location"
                      Command="{Binding OpenSelectedConflictCommand}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
              <ListBox ItemsSource="{Binding Conflicts}"
                       SelectedItem="{Binding SelectedConflict}"
                       BorderThickness="0"
                       Background="Transparent">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="42,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8"
                          Margin="0,3">
                      <TextBlock Text="{Binding Time}"
                                 Classes="secondary"
                                 FontSize="11" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Path}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <TextBlock Grid.Row="1"
                                 Grid.Column="1"
                                 Text="{Binding Details}"
                                 Classes="secondary"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border Padding="10"
                MaxHeight="320"
                CornerRadius="6"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="10">
              <Grid ColumnDefinitions="*,Auto"
                    ColumnSpacing="8">
                <TextBlock Text="Folders"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="+"
                        Classes="icon primary"
                        ToolTip.Tip="Add sync folder"
                        Command="{Binding ShowAddSyncPairCommand}"
                        VerticalAlignment="Center" />
              </Grid>

              <Grid Grid.Row="1">
                <Border Padding="9"
                        CornerRadius="6"
                        Background="{DynamicResource CottonSurfaceMutedBrush}"
                        BorderBrush="{DynamicResource CottonBorderBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Top"
                        IsVisible="{Binding HasNoSyncPairs}">
                  <StackPanel Spacing="1"
                              VerticalAlignment="Center">
                    <TextBlock Text="No folders yet"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="Choose local and Cotton Cloud folders."
                               Classes="secondary"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Border>

                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="7"
                      IsVisible="{Binding HasSyncPairs}">
                  <ScrollViewer MaxHeight="176"
                                VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SyncPairs}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Padding="8"
                                  Margin="0,0,0,7"
                                  CornerRadius="6"
                                  Background="{DynamicResource CottonSurfaceMutedBrush}">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="10">
                              <TextBlock Text="{Binding DisplayName}"
                                         FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Status}"
                                         FontSize="12"
                                         Opacity="0.74" />
                              <TextBlock Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding LocalPath}"
                                         ToolTip.Tip="{Binding LocalPath}"
                                         FontSize="12"
                                         TextTrimming="CharacterEllipsis"
                                         Opacity="0.74" />
                              <TextBlock Grid.Row="2"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding RemotePath}"
                                         ToolTip.Tip="{Binding RemotePath}"
                                         FontSize="12"
                                         TextTrimming="CharacterEllipsis"
                                         Opacity="0.74" />
                              <Button Grid.Column="2"
                                      Grid.RowSpan="3"
                                      Content="↗"
                                      Classes="icon"
                                      ToolTip.Tip="Open local folder"
                                      Command="{Binding $parent[Window].DataContext.OpenFolderCommand}"
                                      CommandParameter="{Binding}"
                                      VerticalAlignment="Center" />
                              <Button Grid.Column="3"
                                      Grid.RowSpan="3"
                                      Content="..."
                                      Classes="icon"
                                      ToolTip.Tip="Manage sync folder"
                                      Command="{Binding $parent[Window].DataContext.ShowSelectedSyncPairEditorCommand}"
                                      CommandParameter="{Binding}"
                                      VerticalAlignment="Center" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>

                  <Border Grid.Row="1"
                          Padding="8"
                          CornerRadius="6"
                          Background="{DynamicResource CottonSurfaceMutedBrush}"
                          BorderBrush="{DynamicResource CottonBorderBrush}"
                          BorderThickness="1"
                          IsVisible="{Binding IsSelectedSyncPairEditorVisible}">
                    <Grid RowDefinitions="Auto,Auto"
                          ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="6"
                          ColumnSpacing="6">
                      <TextBox Text="{Binding SelectedSyncPairEditableDisplayName}"
                               PlaceholderText="Folder name" />
                      <Button Grid.Column="1"
                              Content="✓"
                              Classes="icon"
                              ToolTip.Tip="Save folder name"
                              Command="{Binding SaveSelectedSyncPairNameCommand}" />
                      <Button Grid.Column="2"
                              Content="{Binding SelectedSyncPair.ToggleEnabledIcon}"
                              Classes="icon"
                              ToolTip.Tip="{Binding SelectedSyncPair.ToggleEnabledLabel}"
                              Command="{Binding ToggleSelectedSyncPairEnabledCommand}" />
                      <Button Grid.Column="3"
                              Content="↗"
                              Classes="icon"
                              ToolTip.Tip="Open local folder"
                              Command="{Binding OpenFolderCommand}" />
                      <Button Grid.Column="4"
                              Content="-"
                              Classes="icon"
                              ToolTip.Tip="Remove sync folder"
                              Command="{Binding RemoveSelectedSyncPairCommand}" />
                      <Button Grid.Column="5"
                              Content="x"
                              Classes="icon"
                              ToolTip.Tip="Close folder controls"
                              Command="{Binding CancelSelectedSyncPairEditorCommand}" />
                      <TextBlock Grid.Row="1"
                                 Grid.ColumnSpan="6"
                                 ToolTip.Tip="{Binding SelectedSyncPair.LocalPath}"
                                 Classes="secondary"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding SelectedSyncPair.ModeLabel}" />
                        <Run Text=" · " />
                        <Run Text="{Binding SelectedSyncPair.LocalPath}" />
                      </TextBlock>
                    </Grid>
                  </Border>

                  <Border Grid.Row="2"
                          Padding="8"
                          CornerRadius="6"
                          Background="{DynamicResource CottonErrorSoftBrush}"
                          BorderBrush="{DynamicResource CottonErrorBrush}"
                          BorderThickness="1"
                          IsVisible="{Binding IsRemoveSyncPairConfirmationVisible}">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="6"
                          RowSpacing="2">
                      <TextBlock Text="{Binding RemoveSyncPairConfirmationTitle}"
                                 FontSize="12"
                                 FontWeight="SemiBold"
                                 TextTrimming="CharacterEllipsis" />
                      <Button Grid.Column="1"
                              Content="Cancel"
                              Classes="compact"
                              Command="{Binding CancelRemoveSyncPairCommand}" />
                      <Button Grid.Column="2"
                              Content="Remove"
                              Classes="compact"
                              Command="{Binding ConfirmRemoveSelectedSyncPairCommand}" />
                      <TextBlock Grid.Row="1"
                                 Grid.ColumnSpan="3"
                                 Text="{Binding RemoveSyncPairConfirmationPath}"
                                 ToolTip.Tip="{Binding RemoveSyncPairConfirmationPath}"
                                 Classes="secondary"
                                 FontSize="11"
                                 TextTrimming="CharacterEllipsis" />
                    </Grid>
                  </Border>

                </Grid>
              </Grid>
            </Grid>
        </Border>
      </StackPanel>

      <Border Grid.Row="1"
              Padding="10"
              CornerRadius="6"
              Background="{DynamicResource CottonSurfaceBrush}"
              BorderBrush="{DynamicResource CottonBorderBrush}"
              BorderThickness="1">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="8">
              <TextBlock Text="Activity"
                         FontSize="16"
                         FontWeight="SemiBold" />
              <Grid Grid.Row="1">
                <StackPanel Spacing="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HasNoActivities}">
                  <TextBlock Text="No activity yet"
                             FontSize="13"
                             FontWeight="SemiBold"
                             HorizontalAlignment="Center" />
                  <TextBlock Text="Sync events will appear here."
                             Classes="secondary"
                             FontSize="12"
                             HorizontalAlignment="Center" />
                </StackPanel>
                <ListBox ItemsSource="{Binding Activities}"
                         BorderThickness="0"
                         Background="Transparent"
                         IsVisible="{Binding HasActivities}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="42,*"
                            RowDefinitions="Auto,Auto"
                            ColumnSpacing="8"
                            Margin="0,4">
                        <TextBlock Text="{Binding Time}"
                                   FontSize="12"
                                   Opacity="0.68" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Details}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Text="{Binding Path}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Opacity="0.68" />
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Grid>
      </Border>

      <Border Background="{DynamicResource CottonOverlayBrush}"
              IsVisible="{Binding IsAddSyncPairWizardVisible}">
        <Border MaxWidth="372"
                Margin="10"
                Padding="12"
                CornerRadius="7"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto,*"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding AddSyncPairWizardTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding AddSyncPairWizardSubtitle}"
                           Classes="secondary"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="x"
                      Classes="icon"
                      ToolTip.Tip="Cancel"
                      Command="{Binding CancelAddSyncPairCommand}" />
            </Grid>

            <Border Grid.Row="1"
                    Padding="8"
                    CornerRadius="6"
                    Background="{DynamicResource CottonErrorSoftBrush}"
                    BorderBrush="{DynamicResource CottonErrorBrush}"
                    BorderThickness="1"
                    ToolTip.Tip="{Binding ActionRequiredMessage}"
                    IsVisible="{Binding HasActionRequired}">
              <TextBlock Text="{Binding ActionRequiredMessage}"
                         Classes="secondary"
                         FontSize="12"
                         TextTrimming="CharacterEllipsis" />
            </Border>

            <Grid Grid.Row="2">
              <StackPanel Spacing="12"
                          IsVisible="{Binding IsAddSyncPairLocalStepVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                  <Border Width="24"
                          Height="24"
                          CornerRadius="12"
                          Background="{DynamicResource CottonPrimaryBrush}">
                    <TextBlock Text="1"
                               Foreground="{DynamicResource CottonPrimaryTextBrush}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="Local folder"
                             FontWeight="SemiBold"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2"
                             Text="Cloud folder"
                             Classes="secondary"
                             FontSize="12"
                             VerticalAlignment="Center" />
                </Grid>

                <Button HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Padding="14"
                        Command="{Binding BrowseLocalFolderCommand}">
                  <Grid RowDefinitions="Auto,Auto"
                        RowSpacing="4">
                    <TextBlock Text="+"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Grid.Row="1"
                               Text="Choose folder"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </Grid>
                </Button>
              </StackPanel>

              <StackPanel Spacing="12"
                          IsVisible="{Binding IsAddSyncPairCloudStepVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                  <Border Width="24"
                          Height="24"
                          CornerRadius="12"
                          Background="{DynamicResource CottonSuccessBrush}">
                    <TextBlock Text="1"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>
                  <TextBlock Grid.Column="1"
                             Text="{Binding LocalFolderPath}"
                             ToolTip.Tip="{Binding LocalFolderPath}"
                             TextTrimming="CharacterEllipsis"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="2"
                          Content="Change"
                          Classes="compact"
                          Command="{Binding BrowseLocalFolderCommand}" />
                </Grid>

                <Border Padding="10"
                        CornerRadius="6"
                        Background="{DynamicResource CottonSurfaceMutedBrush}">
                  <Grid RowDefinitions="Auto,Auto,160,Auto"
                        RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                          ColumnSpacing="6">
                      <Button Content="←"
                              Classes="icon"
                              ToolTip.Tip="Go to parent folder"
                              Command="{Binding RemoteFolderUpCommand}" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding RemoteBrowserPath}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <Button Grid.Column="2"
                              Content="+"
                              Classes="icon primary"
                              ToolTip.Tip="Create cloud folder"
                              Command="{Binding ShowCreateRemoteFolderCommand}" />
                      <Button Grid.Column="3"
                              Content="→"
                              Classes="icon"
                              ToolTip.Tip="Open selected cloud folder"
                              Command="{Binding OpenRemoteFolderCommand}" />
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="6"
                          IsVisible="{Binding IsCreateRemoteFolderVisible}">
                      <TextBox Text="{Binding NewRemoteFolderName}"
                               PlaceholderText="New folder name" />
                      <Button Grid.Column="1"
                              Content="✓"
                              Classes="icon"
                              ToolTip.Tip="Create folder"
                              Command="{Binding CreateRemoteFolderCommand}" />
                      <Button Grid.Column="2"
                              Content="x"
                              Classes="icon"
                              ToolTip.Tip="Cancel"
                              Command="{Binding CancelCreateRemoteFolderCommand}" />
                    </Grid>

                    <Grid Grid.Row="2">
                      <StackPanel Spacing="3"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding HasNoRemoteFolders}">
                        <TextBlock Text="No folders here"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="The current cloud folder can still be selected."
                                   Classes="secondary"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                      <ListBox ItemsSource="{Binding RemoteFolders}"
                               SelectedItem="{Binding SelectedRemoteFolder}"
                               BorderThickness="0"
                               Background="Transparent"
                               DoubleTapped="RemoteFoldersListBox_DoubleTapped"
                               IsVisible="{Binding HasRemoteFolders}">
                        <ListBox.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8"
                                  Margin="0,5">
                              <TextBlock Text="›"
                                         Classes="secondary"
                                         VerticalAlignment="Center" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                            </Grid>
                          </DataTemplate>
                        </ListBox.ItemTemplate>
                      </ListBox>
                    </Grid>

                    <TextBlock Grid.Row="3"
                               Text="{Binding RemoteFolderSelectionLabel}"
                               ToolTip.Tip="{Binding RemoteFolderSelectionLabel}"
                               Classes="secondary"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </Grid>
                </Border>

                <StackPanel Spacing="7"
                            IsVisible="{Binding IsFutureSyncModesVisible}">
                  <TextBlock Text="Sync mode"
                             FontSize="12"
                             FontWeight="SemiBold" />
                  <Grid ColumnDefinitions="*,*"
                        ColumnSpacing="8">
                    <Border Padding="9"
                            CornerRadius="6"
                            Background="{DynamicResource CottonPrimarySoftBrush}"
                            BorderBrush="{DynamicResource CottonPrimaryBrush}"
                            BorderThickness="1">
                      <Grid RowDefinitions="Auto,Auto"
                            RowSpacing="2">
                        <TextBlock Text="{Binding SelectedSyncModeLabel}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Text="Available"
                                   Classes="secondary"
                                   FontSize="11" />
                      </Grid>
                    </Border>
                    <Border Grid.Column="1"
                            Padding="9"
                            CornerRadius="6"
                            Background="{DynamicResource CottonSurfaceMutedBrush}"
                            BorderBrush="{DynamicResource CottonBorderBrush}"
                            BorderThickness="1"
                            Opacity="0.62">
                      <Grid RowDefinitions="Auto,Auto"
                            RowSpacing="2">
                        <TextBlock Text="Virtual files"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Row="1"
                                   Text="Not implemented"
                                   Classes="secondary"
                                   FontSize="11" />
                      </Grid>
                    </Border>
                  </Grid>
                </StackPanel>

                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                  <Button Grid.Column="1"
                          Content="Use this folder"
                          Classes="primary"
                          ToolTip.Tip="Start syncing with the current cloud folder"
                          Command="{Binding AddSyncPairCommand}" />
                </Grid>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Border>

      <Border Background="{DynamicResource CottonOverlayBrush}"
              IsVisible="{Binding IsSettingsVisible}">
        <Border MaxWidth="372"
                Margin="10"
                Padding="12"
                CornerRadius="7"
                Background="{DynamicResource CottonSurfaceBrush}"
                BorderBrush="{DynamicResource CottonBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
          <Grid RowDefinitions="Auto,*"
                RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="Settings"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="Account, startup, and diagnostics"
                           Classes="secondary"
                           FontSize="12"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="x"
                      Classes="icon"
                      ToolTip.Tip="Close"
                      Command="{Binding CloseSettingsCommand}" />
            </Grid>

            <TabControl Grid.Row="1"
                        Classes="settingsTabs"
                        FontSize="13"
                        SelectedIndex="{Binding SelectedSettingsTabIndex}">
              <TabItem Header="Account">
                <StackPanel Margin="0,10,0,0"
                            Spacing="14">
                  <StackPanel Spacing="3">
                    <TextBlock Text="Signed in as"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AccountName}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding ServerUrl}"
                               Classes="secondary"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>

                  <Grid ColumnDefinitions="*,Auto"
                        ColumnSpacing="8">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Cotton Sync Desktop"
                                 FontWeight="SemiBold" />
                      <TextBlock Text="Full mirror sync"
                                 Classes="secondary"
                                 FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Sign out"
                            Classes="compact"
                            Command="{Binding SignOutCommand}" />
                  </Grid>

                  <Border Height="1"
                          Background="{DynamicResource CottonBorderBrush}" />

                  <StackPanel Spacing="3">
                    <TextBlock Text="About"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Cross-platform folder sync for Cotton Cloud."
                               Classes="secondary"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding AppVersion}"
                               Classes="secondary"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </StackPanel>
              </TabItem>

              <TabItem Header="Start"
                       ToolTip.Tip="Startup">
                <StackPanel Margin="0,10,0,0"
                            Spacing="7">
                  <CheckBox Content="Launch on startup"
                            IsVisible="{Binding IsStartWithOperatingSystemSupported}"
                            IsChecked="{Binding StartWithOperatingSystem}" />
                  <TextBlock Text="{Binding AutostartStatusText}"
                             Classes="secondary"
                             FontSize="12"
                             TextWrapping="Wrap" />
                  <TextBlock Text="{Binding TrayLifecycleStatusText}"
                             Classes="secondary"
                             FontSize="12"
                             TextWrapping="Wrap"
                             IsVisible="{Binding IsTrayLifecycleUnsupported}" />
                </StackPanel>
              </TabItem>

              <TabItem Header="Prefs">
                <StackPanel Margin="0,10,0,0"
                            Spacing="14">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Appearance"
                               FontWeight="SemiBold" />
                    <ComboBox SelectedIndex="{Binding ThemeModeIndex}"
                              HorizontalAlignment="Stretch">
                      <ComboBoxItem Content="System" />
                      <ComboBoxItem Content="Light" />
                      <ComboBoxItem Content="Dark" />
                    </ComboBox>
                  </StackPanel>

                  <Border Height="1"
                          Background="{DynamicResource CottonBorderBrush}" />

                  <StackPanel Spacing="6">
                    <TextBlock Text="Notifications"
                               FontWeight="SemiBold" />
                    <CheckBox Content="Show notifications"
                              IsChecked="{Binding EnableNotifications}" />
                    <TextBlock Text="Initial sync, conflicts, and action-required errors."
                               Classes="secondary"
                               FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </StackPanel>
              </TabItem>

              <TabItem Header="Diag"
                       ToolTip.Tip="Diagnostics">
                <ScrollViewer Margin="0,10,0,0"
                              VerticalScrollBarVisibility="Auto">
                  <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                      <Button Content="Run checks"
                              Classes="compact"
                              ToolTip.Tip="Run desktop self-test"
                              Command="{Binding SelfTestCommand}" />
                      <Button Content="Export bundle"
                              Classes="compact"
                              ToolTip.Tip="Export diagnostics bundle"
                              Command="{Binding ExportDiagnosticsCommand}" />
                    </StackPanel>
                    <Border Padding="8"
                            CornerRadius="6"
                            Background="{DynamicResource CottonSurfaceMutedBrush}"
                            IsVisible="{Binding HasLastDiagnosticsBundlePath}">
                      <Grid ColumnDefinitions="*,Auto"
                            ColumnSpacing="6">
                        <TextBlock Text="{Binding LastDiagnosticsBundlePath}"
                                   Classes="secondary"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip.Tip="{Binding LastDiagnosticsBundlePath}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Open"
                                Classes="compact"
                                ToolTip.Tip="Open diagnostics folder"
                                Command="{Binding OpenDiagnosticsBundleFolderCommand}" />
                      </Grid>
                    </Border>
                    <TextBlock Text="Run checks to verify this computer."
                               Classes="secondary"
                               FontSize="12"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasNoSelfTestItems}" />
                    <Border BorderBrush="{DynamicResource CottonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            IsVisible="{Binding HasSelfTestItems}">
                      <ItemsControl ItemsSource="{Binding SelfTestItems}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="8"
                                  Margin="8,6">
                              <TextBlock Text="{Binding Name}"
                                         FontSize="12"
                                         FontWeight="SemiBold"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding ResultText}"
                                         Classes="secondary"
                                         FontSize="12" />
                              <TextBlock Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding Details}"
                                         Classes="secondary"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>
                    <Border BorderBrush="{DynamicResource CottonBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                      <ItemsControl ItemsSource="{Binding DiagnosticsItems}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Grid ColumnDefinitions="108,*"
                                  ColumnSpacing="8"
                                  Margin="8,5">
                              <TextBlock Text="{Binding Label}"
                                         Classes="secondary"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="1"
                                         Text="{Binding Value}"
                                         FontSize="11"
                                         TextTrimming="CharacterEllipsis" />
                            </Grid>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Border>
                  </StackPanel>
                </ScrollViewer>
              </TabItem>
            </TabControl>
          </Grid>
        </Border>
      </Border>
    </Grid>
  </Grid>
</Window>
